# VLM Provider Configuration
# Options: "openai", "ollama", or leave blank for "mock"
VLM_PROVIDER=openai
VLM_MODEL=gpt-4o

# OpenAI Configuration
OPENAI_API_KEY=sk-your-key-here

# Ollama Configuration (if using local models)
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# OLLAMA_API_KEY=any-string
# VLM_PROVIDER=ollama
# VLM_MODEL=gemma3

# Debugging
DEBUG_VLM=false
JSON_LOGS=true

# Authentication (comma-separated tokens; leave blank to disable auth for local dev)
AUTH_TOKENS=your-secret-token,another-token

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Workspace Configuration
WORKSPACE_BASE_DIR=workspaces

# File Upload Configuration
MAX_UPLOAD_SIZE_MB=500

# Rate Limiting Configuration
RATE_LIMIT_MAX_CALLS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Job Queue Configuration
MAX_JOB_WORKERS=2